# EarnSafe — Environment Variables
# Copy this file to .env and fill in the values before running the backend.

# ── Database ──────────────────────────────────────────────────────────────────
# MySQL username (default: root)
DB_USERNAME=root
# MySQL password for the earnsafe_db database
DB_PASSWORD=your_mysql_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters). Use a long random string.
JWT_SECRET=EarnSafe2026SecretKeyForJWTAuthenticationMustBeAtLeast256BitsLong

# ── OpenWeatherMap (optional) ─────────────────────────────────────────────────
# Obtain a free key at https://openweathermap.org/api
# Leave blank to use mock/simulated weather events only.
WEATHER_API_KEY=

# ── Seed Data ─────────────────────────────────────────────────────────────────
# Set to true to seed demo users/zones on startup (only if DB is empty).
APP_SEED_ENABLED=true
